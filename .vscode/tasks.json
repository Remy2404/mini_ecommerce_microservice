			"label": "verify-swagger-openapi",
			"type": "shell",
			"command": "uv",
			"args": [
				"run",
				"python",
				"-c",
				"import json, urllib.request; data=json.load(urllib.request.urlopen('http://127.0.0.1:8010/openapi.json')); paths=data['paths']; print('HAS_WSO2_GATEWAY', any('WSO2 Gateway' in op.get('tags', []) for p in paths.values() for op in p.values())); print('WSO2_GATEWAY_LOGIN', paths.get('/api/v1/auth/login', {}).get('post', {}).get('tags')); print('HAS_ROOT_AUTH_LOGIN', '/auth/login' in paths); print('HAS_INTERNAL_LOGIN', '/internal/wso2/login' in paths)"
			],
			"isBackground": false
		},
