              "    pm.expect(jsonData).to.have.property('status');",
              "    pm.environment.set('order_id', jsonData.id);",
              "});",
              "",
              "// Assertion 3: Order status should be one of expected values",
              "pm.test('Order status is valid', function() {",
              "    var jsonData = pm.response.json();",
              "    var validStatuses = ['pending', 'confirmed', 'processing', 'created'];",
              "    pm.expect(validStatuses).to.include(jsonData.status.toLowerCase());",
              "});"
            ]
