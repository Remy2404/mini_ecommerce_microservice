    {
      "name": "P3-A10: Unauthorized Route - Sad Path",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Assertion 1: Status code should be 401 or 403 (Unauthorized/Forbidden)",
              "pm.test('Status code is 401 or 403 (Security enforced)', function() {",
              "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
              "});",
              "",
              "// Assertion 2: Response should contain security error message",
              "pm.test('Response contains security message', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('detail');",
              "    pm.expect(jsonData.detail.toLowerCase()).to.include.oneOf(['unauthorized', 'forbidden', 'invalid token']);",
              "});",
              "",
              "// Assertion 3: Response should not contain sensitive data",
              "pm.test('Response does not expose sensitive data', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.not.have.property('data');",
              "    pm.expect(jsonData).to.not.have.property('items');",
              "});"
            ]
          }
        }
