    {
      "name": "P3-A06: Product Delete - Happy Path",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Assertion 1: Status code should be 204 or 200",
              "pm.test('Status code is 204 or 200 (Success)', function() {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});",
              "",
              "// Assertion 2: Verify product no longer exists (follow-up check)",
              "pm.test('Delete operation completed', function() {",
              "    // After successful delete, status should indicate no content or ok",
              "    pm.expect([200, 204]).to.include(pm.response.code);",
              "});",
              "",
              "// Assertion 3: Response should not contain product data",
              "pm.test('Response does not contain deleted product data', function() {",
              "    if (pm.response.code === 200) {",
              "        var jsonData = pm.response.json();",
              "        // Verify the response indicates deletion",
              "        pm.expect(jsonData).to.exist;",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/products/{{product_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "products", "{{product_id}}"]
        }
      },
      "response": []
