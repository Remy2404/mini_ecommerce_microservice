  "item": [
    {
      "name": "P3-A01: Auth/Login - Happy Path",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Assertion 1: Status code should be 200",
              "pm.test('Status code is 200', function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Assertion 2: Response should contain access_token field",
              "pm.test('Response contains access_token', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('access_token');",
              "    pm.expect(jsonData.access_token).to.be.a('string');",
              "    pm.expect(jsonData.access_token.length).to.be.greaterThan(0);",
              "});",
              "",
              "// Assertion 3: Response should contain token_type",
              "pm.test('Response contains token_type', function() {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('token_type');",
              "});",
              "",
              "// Store token for subsequent requests",
              "var jsonData = pm.response.json();",
              "pm.environment.set('auth_token', jsonData.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"username\\\": \\\"{{test_user}}\\\",\\n  \\\"password\\\": \\\"{{test_password}}\\\",\\n  \\\"scope\\\": \\\"openid profile email\\\"\\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      },
      "response": []
    },
