# Environment variables for mini_ecommerce_microservice.
# Copy to .env for local development. Do not commit real secrets.

APP_ENV=local
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# API Gateway
API_GATEWAY_SERVICE_NAME=api-gateway
API_GATEWAY_PORT=8000
GATEWAY_AUTH_ENABLED=false
GATEWAY_REQUEST_TIMEOUT_SECONDS=10
GATEWAY_RATE_LIMIT_ENABLED=false
GATEWAY_RATE_LIMIT_PER_MINUTE=60

# WSO2 Identity Server
WSO2_BASE_URL=https://localhost:9443
WSO2_ISSUER=https://localhost:9443/oauth2/token
WSO2_AUDIENCE=mini-ecommerce-api
WSO2_JWKS_URL=https://localhost:9443/oauth2/jwks
WSO2_TOKEN_URL=https://localhost:9443/oauth2/token
WSO2_INTROSPECTION_URL=https://localhost:9443/oauth2/introspect
WSO2_VERIFY_SSL=false
WSO2_REQUEST_TIMEOUT_SECONDS=10
WSO2_CLIENT_ID=replace-with-local-client-id
WSO2_CLIENT_SECRET=replace-with-local-client-secret
JWT_ALGORITHM=RS256
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Service names and URLs
AUTH_SERVICE_NAME=auth-service
PRODUCT_SERVICE_NAME=product-service
CART_SERVICE_NAME=cart-service
ORDER_SERVICE_NAME=order-service
PAYMENT_SERVICE_NAME=payment-service
AUTH_SERVICE_PORT=8005
PRODUCT_SERVICE_PORT=8001
CART_SERVICE_PORT=8002
ORDER_SERVICE_PORT=8003
PAYMENT_SERVICE_PORT=8004
AUTH_SERVICE_URL=http://localhost:8005
PRODUCT_SERVICE_URL=http://localhost:8001
CART_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8004

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=ecommerce.events
ORDER_CREATED_ROUTING_KEY=order.created.v1
PAYMENT_SUCCESS_ROUTING_KEY=payment.succeeded.v1
PAYMENT_FAILED_ROUTING_KEY=payment.failed.v1
ORDER_CONFIRMED_ROUTING_KEY=order.confirmed.v1
ORDER_CANCELLED_ROUTING_KEY=order.cancelled.v1
CART_RESTORED_ROUTING_KEY=cart.restored.v1
ORDER_CREATED_QUEUE=order.created.queue
PAYMENT_RESULT_QUEUE=payment.result.queue
CART_RESTORE_QUEUE=cart.restore.queue
DEAD_LETTER_QUEUE=dead.letter.queue

# Databases
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
PRODUCTS_DATABASE_NAME=products
ORDERS_DATABASE_NAME=orders
PAYMENTS_DATABASE_NAME=payments
AUTH_DATABASE_NAME=auth
PRODUCTS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/products
ORDERS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/orders
PAYMENTS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/payments
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auth

# Valkey
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_URL=redis://localhost:6379/0

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_RESOURCE_ATTRIBUTES=service.namespace=mini-ecommerce
OTEL_TRACES_SAMPLER=parentbased_always_on

# TLS and certificate validation
TLS_ENABLED=false
CERT_VALIDATION_ENABLED=false
CA_CERT_PATH=certs/ca.pem
CLIENT_CERT_PATH=certs/client.pem
CLIENT_KEY_PATH=certs/client-key.pem

# Payment simulation
PAYMENT_SUCCESS_RATE=0.9
PAYMENT_MIN_DELAY_MS=100
PAYMENT_MAX_DELAY_MS=500

# Cache and rate limits
PRODUCT_CACHE_TTL_SECONDS=300
CART_CACHE_TTL_SECONDS=300
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
